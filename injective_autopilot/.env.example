# Injective Autopilot — environment variables
# Copy to .env and fill in your values

# Mode: BACKTEST | PAPER | LIVE (default: PAPER)
INJ_MODE=PAPER

# Network: mainnet | testnet (default: testnet)
INJ_NETWORK=testnet

# Market (INJ/USDT PERP mainnet)
INJ_MARKET_ID=0x17ef48032cb24375ba7c2e39f384e56433bcab20d403119599db037416bcb36d

# Wallet (required for LIVE mode only — NEVER commit to git)
INJ_PRIVATE_KEY=
INJ_SUBACCOUNT_INDEX=0
INJ_FEE_RECIPIENT=

# Capital
INJ_CAPITAL_USDT=1000.0

# Risk settings
INJ_MAX_POSITION_PCT=0.10
INJ_MAX_LEVERAGE=5.0
INJ_MAX_DAILY_DRAWDOWN_PCT=0.05

# Claude
INJ_CLAUDE_MODEL=claude-sonnet-4-6
INJ_CLAUDE_TIMEOUT_SEC=90
INJ_CLAUDE_MIN_CONFIDENCE=0.65
INJ_USE_SUBPROCESS=true               # true = CLI OAuth (default), false = SDK (needs ANTHROPIC_API_KEY)

# Database
INJ_DB_URL=sqlite+aiosqlite:///injective_autopilot.db

# Dashboard
INJ_DASHBOARD_HOST=127.0.0.1
INJ_DASHBOARD_PORT=8080
