# ============================================================
# solana_executor.py — configurazione
# ============================================================
# 1. Copia: cp .env.example .env
# 2. Riempi i valori (MAI committare .env su git!)
# ============================================================

# --- Wallet Solana ---
# Esporta da Phantom: Settings → Security → Export Private Key
# Formato accettato: base58 (stringa ~88 char) OPPURE array JSON [12,34,...]
SOLANA_PRIVATE_KEY=INSERISCI_QUI_LA_TUA_CHIAVE_PRIVATA

# --- RPC Solana ---
# Gratuiti: https://api.mainnet-beta.solana.com  /  https://rpc.ankr.com/solana
# Consigliato in produzione: Helius / QuickNode (meno rate limit)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Modalità ---
# true  = nessuna tx reale (test sicuro)
# false = trade reali (ATTENZIONE!)
DRY_RUN=true

# --- Sizing ---
# Inizia con 10, poi scala a 100 quando è tutto verificato
TRADE_SIZE_USDC=10.0

# --- Sicurezza ---
# Blocca lo swap se il price impact supera questa soglia (%)
MAX_PRICE_IMPACT_PCT=3.0

# Slippage per sistema (basis points: 100 = 1%)
SLIPPAGE_DEFI_BPS=200
SLIPPAGE_V2_BPS=150
SLIPPAGE_V3_BPS=100
SLIPPAGE_V3_LARGE_BPS=50
SLIPPAGE_PUMP_GRAD_BPS=800   # 8% — token illiquidi appena graduati

# Sistemi abilitati: "" = tutti, "pump_grad" = solo pump.fun, "pump_grad,defi" = due sistemi
# Usare "pump_grad" per il test iniziale con wallet reale
SYSTEMS_ENABLED=pump_grad

# Massimo posizioni aperte contemporaneamente
MAX_OPEN_POSITIONS=3

# ============================================================
# bsc_executor.py — configurazione BSC
# ============================================================

# --- Wallet BSC (stesso formato Ethereum, chiave privata hex 64 char) ---
# Esporta da MetaMask: Account Details → Export Private Key
BSC_PRIVATE_KEY=INSERISCI_QUI_LA_TUA_CHIAVE_PRIVATA_BSC

# --- RPC BSC ---
# Gratuiti: https://bsc-dataseed.binance.org/ / https://rpc.ankr.com/bsc
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# --- Modalità BSC ---
BSC_DRY_RUN=true

# --- Sizing BSC ---
BSC_TRADE_SIZE_USDT=10.0

# --- Sicurezza BSC ---
BSC_MAX_IMPACT_PCT=3.0
BSC_SLIPPAGE_BPS=200
BSC_GAS_PRICE_GWEI=5.0
BSC_MAX_OPEN_POSITIONS=5

DRY_RUN=false
TRADE_SIZE_USDC=20
MAX_PRICE_IMPACT_PCT=5.0     #← alzato: pump.fun ha impatto alto
SLIPPAGE_PUMP_GRAD_BPS=800
SYSTEMS_ENABLED=pump_grad
MAX_OPEN_POSITIONS=3

# ============================================================
# Base chain (executor live) + Helius
# ============================================================
EXECUTOR_CHAINS=base
BASE_PRIVATE_KEY=INSERISCI_CHIAVE_PRIVATA_BASE
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/LA_TUA_KEY
BASE_DRY_RUN=false
BASE_TRADE_SIZE_ETH=0.006
BASE_MAX_OPEN_POSITIONS=3
HELIUS_API_KEY=

# ============================================================
# Notifiche email (SMTP Gmail App Password — 16 char)
# ============================================================
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your@gmail.com
SMTP_TO=your@gmail.com

# ============================================================
# API dati di mercato
# ============================================================
COINGECKO_API_KEY=
COINGECKO_API_KEY_SIM=
CMC_API_KEY=
