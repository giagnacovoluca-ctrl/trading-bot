# bot_telegram — copia in `.env` (gitignored). NON committare.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-...           # da @BotFather
TELEGRAM_FREE_CHANNEL_ID=-1001234567890     # canale gratuito (teaser, ritardato)
TELEGRAM_PREMIUM_CHANNEL_ID=-1009876543210  # canale a pagamento (real-time)
TELEGRAM_VIP_CHANNEL_ID=                     # opzionale: canale VIP (pre_grad/mirror). Vuoto = usa Premium
TELEGRAM_ADMIN_CHAT_ID=                      # tuo chat_id per comandi admin (/grant, /stats, /broadcast)

# --- Sorgenti dati (default: defi/reports nella root). Vuoto = autodetect ---
# SIGNALS_DIR=../defi/reports
# TRADES_CSV=../defi/reports/live_trades.csv

# --- Publisher ---
FREE_DELAY_MIN=15            # ritardo (min) dei teaser sul canale free
FREE_MIN_PROBABILITY=0.65    # prob minima per mostrare un teaser nel free
PREMIUM_MIN_PROBABILITY=0.0  # premium riceve tutto
POLL_INTERVAL_SEC=5          # frequenza di lettura dei CSV

# --- Monetizzazione ---
PRICE_PREMIUM_USD=49
PRICE_VIP_USD=149
SUB_DAYS=30                  # durata abbonamento in giorni
# Wallet di ricezione pagamenti (RPC riusati da executor/.env: Helius/Alchemy)
PAY_WALLET_SOL=
PAY_WALLET_EVM=
# Contratti USDC (default mainnet; override solo se necessario)
# USDC_BASE_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# USDC_SOL_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
